<Window x:Class="XIVChat_Desktop.ManageTab"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:XIVChat_Desktop"
        mc:Ignorable="d"
        Title="管理选项卡"
        d:DataContext="{d:DesignInstance local:ManageTab}">
    <Grid Margin="8" DataContext="{x:Bind}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 x:Name="TabName"
                 Margin="0,0,0,8"
                 PlaceholderText="Name"
                 Header="名称"
                 Text="{x:Bind Tab.Name, Mode=OneWay}" />
        <CheckBox Grid.Row="1"
                  x:Name="MarkdownToggle"
                  Margin="0,0,0,8"
                  Content="将消息处理为 Markdown"
                  IsChecked="{x:Bind Tab.ProcessMarkdown, Mode=OneWay}" />
        <TabView Grid.Row="2"
                 x:Name="Tabs"
                 IsAddTabButtonVisible="False" />
        <Button Margin="0,8,0,0"
                Grid.Row="3"
                Content="保存"
                Click="Save_Click" />
    </Grid>
</Window>
