<Window x:Class="XIVChat_Desktop.TrustDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:XIVChat_Desktop"
        mc:Ignorable="d"
        Title="密钥验证">
    <Grid Margin="8">

        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0"
                   Grid.Row="0"
                   Text="您正在尝试连接到以前从未连接过的服务器。 请检查服务器并确保以下两个键匹配。" />

        <Grid Grid.Column="0"
              Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="服务器:" />
            <TextBlock x:Name="ServerPublicKey"
                       Grid.Row="1"
                       Grid.Column="0" />
            <Grid Grid.Row="2"
                  Grid.Column="0"
                  Height="24"
                  x:Name="ServerPublicKeyColours">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="0" />
                <Rectangle Grid.Column="1" />
                <Rectangle Grid.Column="2" />
                <Rectangle Grid.Column="3" />
                <Rectangle Grid.Column="4" />
                <Rectangle Grid.Column="5" />
                <Rectangle Grid.Column="6" />
                <Rectangle Grid.Column="7" />
                <Rectangle Grid.Column="8" />
                <Rectangle Grid.Column="9" />
                <Rectangle Grid.Column="10" />
            </Grid>
        </Grid>

        <Grid Grid.Column="0"
              Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="客户端:" />
            <TextBlock x:Name="ClientPublicKey"
                       Grid.Row="1"
                       Grid.Column="0" />
            <Grid Grid.Row="2"
                  Grid.Column="0"
                  Height="24"
                  x:Name="ClientPublicKeyColours">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="0" />
                <Rectangle Grid.Column="1" />
                <Rectangle Grid.Column="2" />
                <Rectangle Grid.Column="3" />
                <Rectangle Grid.Column="4" />
                <Rectangle Grid.Column="5" />
                <Rectangle Grid.Column="6" />
                <Rectangle Grid.Column="7" />
                <Rectangle Grid.Column="8" />
                <Rectangle Grid.Column="9" />
                <Rectangle Grid.Column="10" />
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3"
                   Grid.Column="0"
                   Orientation="Vertical">
            <TextBlock Text="给这个key起个名" />
            <TextBox x:Name="KeyName" />
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Text="两个键是否匹配?" />

        <StackPanel Grid.Row="5"
                   Grid.Column="0"
                   Orientation="Horizontal">
            <Button Click="Yes_Click" Content="是" />
            <Button Click="No_Click" Content="否" />
        </StackPanel>
    </Grid>
</Window>
