<Window x:Class="XIVChat_Desktop.ManageServer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:XIVChat_Desktop"
        mc:Ignorable="d"
        Title="管理服务器"
        d:DataContext="{d:DesignInstance local:ManageServer}">
    <Grid Margin="8" DataContext="{x:Bind}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition MinWidth="200" />
        </Grid.ColumnDefinitions>

        <TextBlock VerticalAlignment="Center"
                   Grid.Row="0"
                   Grid.Column="0"
                   Text="名称" />
        <TextBox Margin="4,0,0,0"
                 Grid.Row="0"
                 Grid.Column="1"
                 x:Name="ServerName"
                 Text="{x:Bind Server.Name, Mode=OneWay}" />

        <TextBlock VerticalAlignment="Center"
                   Grid.Row="1"
                   Grid.Column="0"
                   Text="IP 地址" />
        <TextBox Margin="4,4,0,0"
                 Grid.Row="1"
                 Grid.Column="1"
                 x:Name="ServerHost"
                 Text="{x:Bind Server.Host, Mode=OneWay}" />

        <TextBlock VerticalAlignment="Center"
                   Grid.Row="2"
                   Grid.Column="0"
                   Text="端口号" />
        <TextBox Margin="4,4,0,0"
                 Grid.Row="2"
                 Grid.Column="1"
                 x:Name="ServerPort"
                 Text="{x:Bind Server.Port, Mode=OneWay}"
                 PlaceholderText="14777" />

        <StackPanel Margin="0,8,0,0"
                   Grid.Row="3"
                   Grid.ColumnSpan="2"
                   Grid.Column="0"
                   HorizontalAlignment="Right"
                   Orientation="Horizontal">
            <Button Click="Cancel_Click">
                取消
            </Button>
            <Button Margin="4,0,0,0"
                    Click="Save_Click">
                保存
            </Button>
        </StackPanel>
    </Grid>
</Window>
